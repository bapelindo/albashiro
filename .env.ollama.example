# Environment Variables for Ollama Service

# Ollama API URL (Google Cloud Run)
# After deployment, replace with your actual Cloud Run URL
# Example: https://ollama-api-xxxxx-uc.a.run.app
OLLAMA_API_URL=http://localhost:11434

# Note: For local testing before Cloud Run deployment,
# you can run Ollama locally with Docker:
# docker run -d -p 11434:11434 ollama/ollama
# docker exec -it <container_id> ollama pull gemma2:2b
